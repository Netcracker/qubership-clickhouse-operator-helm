				{
					"name": "Create database",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Successful POST request\", function () {\r",
									"    pm.expect(pm.response.code).to.be.oneOf([201, 202]);\r",
									"});\r",
									"\r",
									"var jsonData = JSON.parse(responseBody);\r",
									"postman.setEnvironmentVariable(\"username\", jsonData.connectionProperties[0].username);\r",
									"postman.setEnvironmentVariable(\"dbname\", jsonData.connectionProperties[0].name);\r",
									"\r",
									"var multiusers = pm.collectionVariables.get('multiusers')\r",
									"\r",
									"if (multiusers == \"true\" ) {\r",
									"postman.setEnvironmentVariable(\"username1\", jsonData.connectionProperties[1].username);\r",
									"postman.setEnvironmentVariable(\"dbname1\", jsonData.connectionProperties[1].name);\r",
									"postman.setEnvironmentVariable(\"username2\", jsonData.connectionProperties[2].username);\r",
									"postman.setEnvironmentVariable(\"dbname2\", jsonData.connectionProperties[2].name);\r",
									"}\r",
									""
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"var dbName = pm.collectionVariables.get('dbname')\r",
									"var userName = pm.collectionVariables.get('username')\r",
									"var pgVersion = pm.collectionVariables.get('pgversion')\r",
									"\r",
									"var body = {\"metadata\": {\"classifier\":{\"namespace\":\"postgres-dbaas\"},\"microserviceName\":\"postgres-sa\",\"data\":\"meta\",\"eschodata\":\"echo\"},\"namePrefix\":\"ffH090A\",\"settings\":{\"pgExtensions\":[\"postgres_fdw\"]}};\r",
									"console.log(pgVersion)\r",
									"\r",
									"var body_str = JSON.stringify(body);\r",
									"pm.environment.set('request_body', body_str);\r",
									""
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
