				{
					"name": "Bulk drop",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {\r",
									"    pm.response.to.have.status(200);\r",
									"});\r",
									"\r",
									"pm.test(\"Bulk drop\", function () {\r",
									"    var jsonData = pm.response.json();\r",
									"    for (let value of jsonData) {\r",
									"    console.log(value);\r",
									"    pm.expect(value['status']).to.equals('DELETED');\r",
									"    }\r",
									"});"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"var body = [\r",
									"        {\r",
									"            \"kind\": \"user\",\r",
									"            \"name\": \"{{username}}\"\r",
									"        },\r",
									"        {\r",
									"            \"kind\": \"user\",\r",
									"            \"name\": \"{{second_user}}\"\r",
									"        },\r",
									"        {\r",
									"            \"kind\": \"database\",\r",
									"            \"name\": \"{{dbname}}\"\r",
									"        }]\r",
									"        ;\r",
									"\r",
									"var multiusers = pm.collectionVariables.get('multiusers')\r",
									"    if (multiusers == \"true\" ) {\r",
									"        body.push(        {\r",
									"            \"kind\": \"user\",\r",
									"            \"name\": \"{{username1}}\"\r",
									"        },        {\r",
									"            \"kind\": \"user\",\r",
									"            \"name\": \"{{username2}}\"\r",
									"        });\r",
									"    }\r",
									"\r",
									"var body_str = JSON.stringify(body);\r",
									"pm.environment.set('request_body', body_str);"
								],
								"type": "text/javascript"
							}
						}
					],
